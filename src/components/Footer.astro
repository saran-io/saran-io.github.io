---
const year = new Date().getFullYear();
---

<footer>
  <div class="container-wide">
    <div class="inner">
      <span class="copy">© {year} — built with <a href="https://astro.build" target="_blank">Astro</a></span>
      <div class="socials">
        <a href="https://x.com/saran_io" target="_blank" rel="noopener">X</a>
        <a href="https://github.com/saran-io" target="_blank" rel="noopener">GitHub</a>
        <a href="https://www.linkedin.com/in/saran-io/" target="_blank" rel="noopener">LinkedIn</a>
        <a href="mailto:saran@tekvo.io">Email</a>
      </div>
    </div>
  </div>
</footer>

<style>
  footer {
    margin-top: 5rem;
    padding: 1.75rem 0;
    border-top: 1px solid var(--border);
  }

  .inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .copy, .copy a { font-size: 0.85rem; color: var(--text-muted); }
  .copy a:hover { color: var(--accent); }

  .socials {
    display: flex;
    gap: 1.5rem;
  }
  .socials a { font-size: 0.85rem; color: var(--text-muted); }
  .socials a:hover { color: var(--accent); }
</style>

---
interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  slug: string;
}

const { title, description, date, tags, slug } = Astro.props;

const formattedDate = new Intl.DateTimeFormat('en-US', {
  year: 'numeric', month: 'short', day: 'numeric',
}).format(date);
---

<a href={`/blog/${slug}`} class="card">
  <time datetime={date.toISOString()}>{formattedDate}</time>
  <div class="middle">
    <span class="title">{title}</span>
    <span class="desc">{description}</span>
  </div>
  <span class="arrow">→</span>
</a>

<style>
  .card {
    display: grid;
    grid-template-columns: 100px 1fr auto;
    align-items: center;
    gap: 1.5rem;
    padding: 0.9rem 0;
    border-bottom: 1px solid var(--border);
    transition: color 0.15s;
    color: inherit;
  }

  .card:first-child { border-top: 1px solid var(--border); }

  .card:hover { color: inherit; }
  .card:hover .title { color: var(--text); }
  .card:hover .arrow { opacity: 1; transform: translateX(3px); }

  time {
    font-size: 0.78rem;
    color: var(--text-faint);
    white-space: nowrap;
    font-variant-numeric: tabular-nums;
  }

  .middle {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    min-width: 0;
  }

  .title {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    transition: color 0.15s;
  }

  .desc {
    font-size: 0.8rem;
    color: var(--text-faint);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .arrow {
    font-size: 0.85rem;
    color: var(--text-muted);
    opacity: 0;
    transition: opacity 0.15s, transform 0.15s;
  }

  @media (max-width: 560px) {
    .card {
      grid-template-columns: 1fr auto;
      gap: 0.75rem;
    }

    time { display: none; }

    .desc { display: none; }
  }
</style>

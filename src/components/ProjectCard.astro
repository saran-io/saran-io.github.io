---
interface Props {
  title: string;
  description: string;
  tags: string[];
  status: 'live' | 'in-progress' | 'archived';
  url?: string;
  github?: string;
  image?: string;
  slug: string;
}

const { title, description, status, slug } = Astro.props;
---

<a href={`/projects/${slug}`} class="card">
  <div class="top">
    <span class="title">{title}</span>
    <span class={`dot ${status}`}></span>
  </div>
  <p>{description}</p>
</a>

<style>
  .card {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 0.9rem 1rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    transition: border-color 0.15s;
    color: inherit;
  }

  .card:hover { border-color: var(--border-strong); color: inherit; }

  .top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .title {
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .dot.live { background: #2d9e6b; }
  .dot.in-progress { background: #d4a017; }
  .dot.archived { background: var(--text-faint); }

  p {
    font-size: 0.78rem;
    color: var(--text-faint);
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

</style>

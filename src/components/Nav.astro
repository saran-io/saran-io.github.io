---
const links = [
  { label: 'Projects', href: '/projects' },
  { label: 'Blog', href: '/blog' },
  { label: 'About', href: '/about' },
];

const current = Astro.url.pathname;
---

<header>
  <nav class="container">
    <div class="left">
      <a href="/" class="logo">saran</a>
      <span class="sep">·</span>
      <div class="social-icons">
        <a href="https://x.com/saran_io" target="_blank" rel="noopener" title="X">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.737-8.835L1.254 2.25H8.08l4.253 5.622 5.911-5.622Zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
        <a href="https://github.com/saran-io" target="_blank" rel="noopener" title="GitHub">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
        </a>
        <a href="https://www.linkedin.com/in/saran-io/" target="_blank" rel="noopener" title="LinkedIn">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
      </div>
    </div>

    <ul>
      {links.map(({ label, href }) => (
        <li>
          <a href={href} class:list={[{ active: current.startsWith(href) }]}>
            {label}
          </a>
        </li>
      ))}
    </ul>

    <button class="menu-toggle" aria-label="Toggle menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </nav>
</header>

<script>
  const toggle = document.querySelector('.menu-toggle') as HTMLButtonElement;
  const ul = document.querySelector('header ul') as HTMLUListElement;
  toggle?.addEventListener('click', () => {
    const open = ul.classList.toggle('open');
    toggle.setAttribute('aria-expanded', String(open));
  });
</script>

<style>
  header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 52px;
    position: relative;
  }

  .left {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .logo {
    font-family: 'Instrument Serif', serif;
    font-size: 1.45rem;
    font-weight: 500;
    letter-spacing: -0.02em;
    color: var(--text);
  }
  .logo:hover { color: var(--text); }

  .sep { color: var(--border-strong); font-size: 1rem; }

  .social-icons {
    display: flex;
    align-items: center;
    gap: 0.65rem;
  }

  .social-icons a {
    color: var(--text-muted);
    display: flex;
    align-items: center;
    transition: color 0.15s;
  }
  .social-icons a:hover { color: var(--text); }

  ul {
    display: flex;
    list-style: none;
    gap: 1.75rem;
  }

  ul a {
    font-size: 0.85rem;
    color: var(--text-muted);
    transition: color 0.15s;
  }
  ul a:hover, ul a.active { color: var(--text); }

  .menu-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    z-index: 1;
  }

  .menu-toggle span {
    display: block;
    width: 20px;
    height: 1.5px;
    background: var(--text);
  }

  @media (max-width: 600px) {
    .menu-toggle { display: flex; }
    .social-icons { display: none; }

    ul {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: var(--bg);
      border-bottom: 1px solid var(--border);
      flex-direction: column;
      gap: 0;
      padding: 0.5rem 0;
    }

    ul.open { display: flex; }
    ul li a { display: block; padding: 0.75rem 1.25rem; font-size: 0.95rem; }
  }
</style>

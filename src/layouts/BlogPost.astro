---
import Base from './Base.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  cover?: string;
}

const { title, description, date, tags, cover } = Astro.props;

const formattedDate = new Intl.DateTimeFormat('en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
}).format(date);
---

<Base title={title} description={description} image={cover}>
  <article>
    <div class="hero">
      {cover && <img class="cover" src={cover} alt={title} />}
      <div class="container">
        <div class="meta">
          <time datetime={date.toISOString()}>{formattedDate}</time>
          <span class="sep">·</span>
          <div class="tags">
            {tags.map(tag => <span class="tag">{tag}</span>)}
          </div>
        </div>
        <h1>{title}</h1>
        <p class="lead">{description}</p>
      </div>
    </div>

    <div class="container">
      <div class="prose">
        <slot />
      </div>

      <div class="back-link">
        <a href="/blog">← All posts</a>
      </div>
    </div>
  </article>
</Base>

<style>
  .hero {
    padding: 3.5rem 0 2rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 2.5rem;
  }

  .cover {
    width: 100%;
    max-height: 420px;
    object-fit: cover;
    border-radius: var(--radius);
    margin-bottom: 2.5rem;
  }

  .meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 1rem;
  }

  .sep { color: var(--border); }
  .tags { display: flex; gap: 0.4rem; flex-wrap: wrap; }

  h1 {
    font-size: clamp(2rem, 5vw, 3.2rem);
    margin-bottom: 1rem;
  }

  .lead {
    font-size: 1.1rem;
    color: var(--text-muted);
    max-width: 600px;
  }

  .back-link {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  .back-link a:hover { color: var(--accent); }
</style>

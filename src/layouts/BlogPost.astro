---
import Base from './Base.astro';
import '../styles/diagram-kit.css';

interface MarkdownHeading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  cover?: string;
  headings?: MarkdownHeading[];
}

const { title, description, date, tags, cover, headings = [] } = Astro.props;

const formattedDate = new Intl.DateTimeFormat('en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
}).format(date);

const tocHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 4);
const showToc = tocHeadings.length >= 2;
---

<Base title={title} description={description} image={cover}>
  <div class="container">
    <div class:list={['post-layout', { 'has-toc': showToc }]}>
      <article class="post">

        <!-- Header -->
        <header>
          <div class="meta">
            <time datetime={date.toISOString()}>{formattedDate}</time>
            {tags.length > 0 && (
              <>
                <span class="dot">·</span>
                <div class="tags">{tags.map(tag => <span class="tag">{tag}</span>)}</div>
              </>
            )}
          </div>
          <h1>{title}</h1>
          <p class="lead">{description}</p>
        </header>

        <!-- Body -->
        <div class="prose">
          <slot />
        </div>

        <!-- Footer -->
        <footer>
          <a href="/blog">← Back to writing</a>
        </footer>

      </article>

      {showToc && (
        <aside class="toc" aria-label="On this page">
          <span class="toc-label">On this page</span>
          <nav>
            {tocHeadings.map((h) => (
              <a
                href={`#${h.slug}`}
                class:list={['toc-link', `depth-${h.depth}`]}
              >
                {h.text}
              </a>
            ))}
          </nav>
        </aside>
      )}
    </div>
  </div>
</Base>

<style>
  .post-layout {
    display: grid;
    grid-template-columns: minmax(0, 720px);
    gap: 0;
    padding-top: 3rem;
    padding-bottom: 5rem;
    align-items: start;
  }

  .post-layout.has-toc {
    grid-template-columns: minmax(0, 720px) minmax(11rem, 14rem);
    column-gap: 2.5rem;
  }

  .post {
    min-width: 0;
  }

  /* Header */
  header { margin-bottom: 3rem; }

  .meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }

  .meta time {
    font-size: 0.8rem;
    color: var(--text-faint);
  }

  .dot { color: var(--text-faint); font-size: 0.8rem; }

  .tags { display: flex; gap: 0.35rem; flex-wrap: wrap; }

  h1 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    line-height: 1.2;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }

  .lead {
    font-size: 1.05rem;
    color: var(--text-muted);
    line-height: 1.7;
    border-left: 3px solid var(--border-strong);
    padding-left: 1rem;
    margin: 0;
  }

  /* Prose overrides for blog reading */
  .prose { font-size: 1.02rem; line-height: 1.85; color: #222; }

  .prose :global(h2) {
    font-size: 1.45rem;
    margin: 2.75rem 0 0.9rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
    letter-spacing: -0.02em;
    scroll-margin-top: 5.5rem;
  }

  .prose :global(h3) {
    font-size: 1.15rem;
    margin: 2rem 0 0.6rem;
    letter-spacing: -0.01em;
    scroll-margin-top: 5.5rem;
  }

  .prose :global(h4) {
    scroll-margin-top: 5.5rem;
  }

  .prose :global(p) { margin-bottom: 1.4rem; }

  .prose :global(strong) { color: var(--text); font-weight: 600; }

  .prose :global(ul), .prose :global(ol) {
    padding-left: 1.4rem;
    margin-bottom: 1.4rem;
  }

  .prose :global(li) { margin-bottom: 0.5rem; }

  .prose :global(img) {
    display: block;
    width: 100%;
    max-width: 100%;
    height: auto;
    border-radius: var(--radius);
    margin: 2rem 0;
    border: 1px solid var(--border);
  }

  /* Embedded labs (e.g. GPT-2 explainer iframe) */
  .prose :global(.explainer-frame) {
    margin: 2rem 0;
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--border);
    background: #0c0d12;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.08);
  }

  .prose :global(.explainer-frame iframe) {
    display: block;
    width: 100%;
    height: 1020px;
    max-height: min(1020px, 92vh);
    border: none;
    vertical-align: top;
  }

  .prose :global(.explainer-caption) {
    margin: -0.5rem 0 2rem;
    font-size: 0.85rem;
    color: var(--text-muted);
    text-align: center;
  }

  .prose :global(.explainer-caption a) {
    border-bottom: 1px solid var(--border-strong);
  }

  @media (max-width: 560px) {
    .prose :global(.explainer-frame iframe) {
      height: 880px;
      max-height: 85vh;
    }
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--border-strong);
    padding: 0.25rem 0 0.25rem 1.25rem;
    color: var(--text-muted);
    font-style: italic;
    margin: 1.75rem 0;
  }

  .prose :global(code) {
    background: #f4f4f4;
    border: 1px solid var(--border);
    padding: 0.15em 0.4em;
    border-radius: 4px;
    font-size: 0.87em;
  }

  .prose :global(pre) {
    background: #f8f8f8;
    border: 1px solid var(--border);
    padding: 1.25rem 1.5rem;
    border-radius: var(--radius);
    overflow-x: auto;
    margin: 1.75rem 0;
  }

  .prose :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    font-size: 0.9em;
    line-height: 1.6;
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 2.5rem 0;
  }

  .prose :global(a) {
    color: var(--text);
    border-bottom: 1px solid var(--border-strong);
    transition: border-color 0.15s;
  }
  .prose :global(a:hover) { border-color: var(--text); }

  /* Footer */
  footer {
    margin-top: 4rem;
    padding-top: 1.75rem;
    border-top: 1px solid var(--border);
  }

  footer a {
    font-size: 0.85rem;
    color: var(--text-muted);
    border: none;
  }
  footer a:hover { color: var(--text); }

  /* Table of contents */
  .toc {
    position: sticky;
    top: 4.5rem;
    align-self: start;
    padding-top: 0.25rem;
  }

  .toc-label {
    display: block;
    font-size: 0.68rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-faint);
    margin-bottom: 0.85rem;
  }

  .toc nav {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    max-height: calc(100vh - 6rem);
    overflow-y: auto;
    padding-right: 0.25rem;
    scrollbar-width: thin;
  }

  .toc-link {
    font-size: 0.78rem;
    line-height: 1.35;
    color: var(--text-muted);
    text-decoration: none;
    border: none;
    transition: color 0.15s;
    border-left: 2px solid transparent;
    padding: 0.2rem 0 0.2rem 0.65rem;
    margin-left: -2px;
  }

  .toc-link:hover {
    color: var(--text);
  }

  .toc-link.depth-3 {
    padding-left: 1.1rem;
    font-size: 0.74rem;
    color: var(--text-faint);
  }

  .toc-link.depth-4 {
    padding-left: 1.45rem;
    font-size: 0.72rem;
    color: var(--text-faint);
  }

  @media (max-width: 960px) {
    .post-layout.has-toc {
      grid-template-columns: minmax(0, 1fr);
    }

    .toc {
      display: none;
    }
  }
</style>

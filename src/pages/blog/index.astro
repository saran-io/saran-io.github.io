---
import Base from '../../layouts/Base.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const allTags = [...new Set(posts.flatMap(p => p.data.tags))].sort();
---

<Base title="Blog — Saran" description="Thoughts on building products, AI, design, and the founder journey.">
  <div class="container">
    <div class="page">
      <div class="header">
        <h1>Writing</h1>
        <p>Thoughts on building, AI, design, and the founder journey.</p>
      </div>

      {allTags.length > 0 && (
        <div class="tag-bar">
          {allTags.map(t => <span class="tag">{t}</span>)}
        </div>
      )}

      {posts.length === 0 ? (
        <p class="empty">No posts yet. Check back soon.</p>
      ) : (
        <div class="posts">
          {posts.map(p => (
            <PostCard
              title={p.data.title}
              description={p.data.description}
              date={p.data.date}
              tags={p.data.tags}
              slug={p.id}
            />
          ))}
        </div>
      )}
    </div>
  </div>
</Base>

<style>
  .page {
    padding: 3rem 0 5rem;
    max-width: 660px;
  }

  .header { margin-bottom: 2rem; }

  h1 { font-size: 1.8rem; margin-bottom: 0.5rem; }

  p { font-size: 0.88rem; color: var(--text-muted); }

  .tag-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 1.75rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
  }

  .posts { display: flex; flex-direction: column; }

  .empty { color: var(--text-muted); font-style: italic; font-size: 0.9rem; }
</style>

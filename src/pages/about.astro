---
import Base from '../layouts/Base.astro';

const experience = [
  {
    role: 'Founding Engineer — AI, CRM & SaaS',
    company: 'Tekvo',
    period: '2021 – Present',
    note: 'AI-augmented product engineering across CRM intelligence, automated workflows, and scalable SaaS infrastructure.',
  },
  {
    role: 'Chief Product Engineer',
    company: 'Milao',
    url: 'https://milao.ai',
    period: '2025 – Present',
    note: 'AI-powered speech intelligence systems for communication training.',
  },
  {
    role: 'AI/ML Product Engineer',
    company: 'Saggezza',
    period: '2019',
    note: 'Enterprise AI/ML solution architecture on GCP and AWS.',
  },
  {
    role: 'CTO & Digital Strategy Lead',
    company: 'Freshconn',
    period: '2014 – 2018',
    note: 'Built and led the full tech org for a D2C agritech platform across two geographies.',
  },
  {
    role: 'Digital Transformation',
    company: 'BNY Mellon',
    period: '2015',
    note: 'Data analytics, web architecture, and digital strategy at scale.',
  },
  {
    role: 'Data Analytics & Application Dev',
    company: 'Cognizant',
    period: '2007 – 2013',
    note: 'Financial risk reporting, ETL, and analytical model development.',
  },
];
---

<Base title="About — Saran" description="Engineer, builder, and founder working at the intersection of AI, product, and software.">
  <div class="container">
    <div class="page">

    <section class="intro">
      <h1>About</h1>
      <p>I'm Saran — an engineer and builder with 15+ years across AI, product, and software. I work at the intersection of ML systems, product thinking, and scalable engineering. Currently building at <a href="https://milao.ai" target="_blank">Milao</a> and Tekvo. This site is where I write, share what I'm building, and think out loud.</p>
      <div class="contact">
        <a href="mailto:saran@tekvo.io">saran@tekvo.io</a>
        <a href="https://www.linkedin.com/in/saran-io/" target="_blank" rel="noopener">LinkedIn</a>
        <a href="https://github.com/saran-io" target="_blank" rel="noopener">GitHub</a>
        <a href="https://calendly.com/saran-io" target="_blank" rel="noopener" class="cal-link" title="Book a time">
          <svg width="13" height="13" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="1" y="3" width="14" height="12" rx="2" stroke="currentColor" stroke-width="1.4"/>
            <path d="M1 7h14" stroke="currentColor" stroke-width="1.4"/>
            <path d="M5 1v3M11 1v3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
          </svg>
          Book a call
        </a>
      </div>
    </section>

    <section class="experience">
      <span class="label">Experience</span>
      <div class="timeline">
        {experience.map(e => (
          <div class="entry">
            <span class="period">{e.period}</span>
            <div class="detail">
              <div class="title-row">
                <span class="role">{e.role}</span>
                <span class="sep">·</span>
                {e.url
                  ? <a href={e.url} target="_blank" rel="noopener" class="company link">{e.company} ↗</a>
                  : <span class="company">{e.company}</span>
                }
              </div>
              <p>{e.note}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    </div>
  </div>
</Base>

<style>
  .page { padding-top: 3rem; padding-bottom: 5rem; }

  /* Intro */
  .intro { margin-bottom: 2.5rem; }

  h1 {
    font-size: 2rem;
    margin-bottom: 1rem;
  }

  .intro p {
    font-size: 0.95rem;
    color: #444;
    line-height: 1.75;
    margin-bottom: 0.6rem;
  }

  .intro a { color: var(--text); border-bottom: 1px solid var(--border-strong); }
  .intro a:hover { border-color: var(--text); }

  .contact {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem 1.25rem;
    margin-top: 1.25rem;
  }

  .contact a {
    font-size: 0.82rem;
    color: var(--text-muted);
    border: none;
  }
  .contact a:hover { color: var(--text); }

  .cal-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }

  /* Experience */
  .label {
    display: block;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-faint);
    margin-bottom: 1.25rem;
  }

  .timeline { display: flex; flex-direction: column; gap: 0; }

  .entry {
    display: grid;
    grid-template-columns: 100px 1fr;
    gap: 1rem;
    padding: 0.85rem 0;
    border-top: 1px solid var(--border);
  }

  .entry:last-child { border-bottom: 1px solid var(--border); }

  .period {
    font-size: 0.75rem;
    color: var(--text-faint);
    padding-top: 0.15rem;
    white-space: nowrap;
    font-variant-numeric: tabular-nums;
  }

  .title-row {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-wrap: wrap;
    margin-bottom: 0.2rem;
  }

  .role {
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--text);
  }

  .sep { color: var(--text-faint); font-size: 0.8rem; }

  .company {
    font-size: 0.82rem;
    color: var(--text-muted);
  }

  .company.link { color: var(--text-muted); }
  .company.link:hover { color: var(--text); }

  .detail p {
    font-size: 0.8rem;
    color: var(--text-faint);
    line-height: 1.5;
  }

  @media (max-width: 500px) {
    .entry { grid-template-columns: 1fr; gap: 0.25rem; }
    .period { font-size: 0.7rem; }
  }
</style>

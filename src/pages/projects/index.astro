---
import Base from '../../layouts/Base.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects'))
  .sort((a, b) => a.data.order - b.data.order);

const live = projects.filter(p => p.data.status === 'live');
const wip = projects.filter(p => p.data.status === 'in-progress');
const archived = projects.filter(p => p.data.status === 'archived');
---

<Base title="Projects — Saran" description="Things I've built — from side projects to production products.">
  <div class="container">
    <div class="page">

    <div class="header">
      <h1>Projects</h1>
      <p>Things I've built — from side projects to production products.</p>
    </div>

    {live.length > 0 && (
      <div class="group">
        <h2 class="group-title"><span class="badge live">Live</span></h2>
        <div class="grid">
          {live.map(p => <ProjectCard title={p.data.title} description={p.data.description} tags={p.data.tags} status={p.data.status} url={p.data.url} github={p.data.github} image={p.data.image} slug={p.id} />)}
        </div>
      </div>
    )}

    {wip.length > 0 && (
      <div class="group">
        <h2 class="group-title"><span class="badge in-progress">In Progress</span></h2>
        <div class="grid">
          {wip.map(p => <ProjectCard title={p.data.title} description={p.data.description} tags={p.data.tags} status={p.data.status} url={p.data.url} github={p.data.github} image={p.data.image} slug={p.id} />)}
        </div>
      </div>
    )}

    {archived.length > 0 && (
      <div class="group">
        <h2 class="group-title"><span class="badge archived">Archived</span></h2>
        <div class="grid">
          {archived.map(p => <ProjectCard title={p.data.title} description={p.data.description} tags={p.data.tags} status={p.data.status} url={p.data.url} github={p.data.github} image={p.data.image} slug={p.id} />)}
        </div>
      </div>
    )}

    {projects.length === 0 && (
      <p class="empty">No projects yet. Check back soon.</p>
    )}

    </div>
  </div>
</Base>

<style>
  .page { padding-top: 3rem; padding-bottom: 5rem; }

  .header { margin-bottom: 2.5rem; }

  h1 { font-size: clamp(1.8rem, 3vw, 2.4rem); margin-bottom: 0.5rem; }
  .header p { font-size: 0.9rem; color: var(--text-muted); }

  .group { margin-bottom: 3rem; }

  .group-title {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
    font-size: 1rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }

  @media (max-width: 560px) {
    .grid { grid-template-columns: 1fr; }
  }

  .empty { color: var(--text-muted); font-style: italic; padding: 4rem 0; }
</style>

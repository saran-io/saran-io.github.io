---
import Base from '../layouts/Base.astro';
import PostCard from '../components/PostCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);

const allProjects = (await getCollection('projects'))
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 4);
---

<Base title="Saran — Builder & Founder" description="I build things at the intersection of product, AI, and design.">

  <!-- Hero -->
  <section class="hero container">
    <div class="eyebrow">Available for new projects</div>
    <h1>I build products <em>people actually use.</em></h1>
    <p class="sub">
      Founder, builder, occasional writer. I share what I learn while shipping
      products at the intersection of AI, design, and software.
    </p>
    <div class="cta">
      <a href="/blog" class="btn-primary">Read the blog</a>
      <a href="/projects" class="btn-ghost">See my work</a>
    </div>
  </section>

  <!-- Recent Posts — prominent first -->
  {allPosts.length > 0 && (
    <section class="section container">
      <div class="section-header">
        <h2>Latest writing</h2>
        <a href="/blog">All posts →</a>
      </div>
      <div class="posts-featured">
        {allPosts.slice(0, 1).map(p => (
          <a href={`/blog/${p.id}`} class="post-hero">
            <div class="post-hero-meta">
              <time datetime={p.data.date.toISOString()}>
                {new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'long', day: 'numeric' }).format(p.data.date)}
              </time>
              <div class="tags">{p.data.tags.slice(0, 3).map((t: string) => <span class="tag">{t}</span>)}</div>
            </div>
            <h3>{p.data.title}</h3>
            <p>{p.data.description}</p>
            <span class="read-more">Read post →</span>
          </a>
        ))}
        <div class="posts-list">
          {allPosts.slice(1).map(p => (
            <PostCard
              title={p.data.title}
              description={p.data.description}
              date={p.data.date}
              tags={p.data.tags}
              slug={p.id}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Projects — secondary -->
  {allProjects.length > 0 && (
    <section class="section container">
      <div class="section-header">
        <h2>Projects</h2>
        <a href="/projects">All projects →</a>
      </div>
      <div class="projects-grid">
        {allProjects.map(p => (
          <ProjectCard
            title={p.data.title}
            description={p.data.description}
            tags={p.data.tags}
            status={p.data.status}
            url={p.data.url}
            github={p.data.github}
            image={p.data.image}
            slug={p.id}
          />
        ))}
      </div>
    </section>
  )}

</Base>

<style>
  .hero {
    padding: 5rem 0 4rem;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
  }

  .eyebrow::before {
    content: '';
    width: 7px;
    height: 7px;
    background: #2d9e6b;
    border-radius: 50%;
    animation: pulse 2.5s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.25; }
  }

  h1 {
    font-size: clamp(2.2rem, 5vw, 3.8rem);
    margin-bottom: 1.25rem;
    color: var(--text);
  }

  h1 em { color: var(--text-muted); font-style: italic; }

  .sub {
    font-size: 1.05rem;
    color: var(--text-muted);
    max-width: 480px;
    margin-bottom: 2.25rem;
    line-height: 1.75;
  }

  .cta { display: flex; gap: 0.75rem; flex-wrap: wrap; }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    padding: 0.6rem 1.35rem;
    background: var(--text);
    color: #fff;
    border-radius: 6px;
    font-weight: 500;
    font-size: 0.9rem;
    transition: opacity 0.15s;
  }
  .btn-primary:hover { opacity: 0.8; color: #fff; }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    padding: 0.6rem 1.35rem;
    border: 1px solid var(--border-strong);
    border-radius: 6px;
    font-size: 0.9rem;
    color: var(--text-muted);
    transition: all 0.15s;
  }
  .btn-ghost:hover { border-color: var(--text); color: var(--text); }

  .section { padding: 2.5rem 0; border-top: 1px solid var(--border); }

  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 1.5rem;
  }

  .section-header h2 { font-size: 1.3rem; }

  .section-header a {
    font-size: 0.82rem;
    color: var(--text-muted);
  }
  .section-header a:hover { color: var(--text); }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 1rem;
  }

  @media (max-width: 520px) {
    .projects-grid { grid-template-columns: 1fr; }
  }

  .posts-featured { display: grid; gap: 0.75rem; }

  .post-hero {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding: 1.75rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    transition: border-color 0.2s, transform 0.2s;
  }

  .post-hero:hover { border-color: var(--border-strong); transform: translateY(-1px); color: inherit; }

  .post-hero-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .post-hero-meta time { font-size: 0.78rem; color: var(--text-faint); }
  .post-hero-meta .tags { display: flex; gap: 0.35rem; }

  .post-hero h3 { font-size: clamp(1.2rem, 3vw, 1.55rem); }

  .post-hero p { color: var(--text-muted); font-size: 0.95rem; }

  .post-hero .read-more {
    font-size: 0.82rem;
    color: var(--text-muted);
    font-weight: 500;
    margin-top: 0.25rem;
  }

  .post-hero:hover .read-more { color: var(--text); }

  .posts-list { display: grid; gap: 0.75rem; }
</style>

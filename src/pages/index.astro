---
import Base from '../layouts/Base.astro';
import PostCard from '../components/PostCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);

const allProjects = (await getCollection('projects'))
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 6);
---

<Base title="Saran — Builder & Founder" description="I build things at the intersection of product, AI, and design.">

  <div class="container page">

    <!-- Hero -->
    <section class="hero">
      <div class="eyebrow"><span class="dot"></span>Available for new projects</div>
      <h1>Engineer. Builder. <em>Occasional writer.</em></h1>
      <p class="sub">Working at the intersection of AI, product, and software. Currently building at Tekvo and Milao.</p>
      <div class="cta">
        <a href="/blog" class="btn-primary">Read the blog</a>
        <a href="/projects" class="btn-ghost">See my work</a>
      </div>
      <div class="socials">
        <a href="https://x.com/saran_io" target="_blank" rel="noopener" title="X / Twitter">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.737-8.835L1.254 2.25H8.08l4.253 5.622 5.911-5.622Zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
        <a href="https://github.com/saran-io" target="_blank" rel="noopener" title="GitHub">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
        </a>
        <a href="https://www.linkedin.com/in/saran-io/" target="_blank" rel="noopener" title="LinkedIn">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
      </div>
    </section>

    <!-- Writing -->
    {allPosts.length > 0 && (
      <section class="section">
        <div class="section-header">
          <span class="section-label">Writing</span>
          <a href="/blog">All posts →</a>
        </div>
        <div class="posts-list">
          {allPosts.map(p => (
            <PostCard
              title={p.data.title}
              description={p.data.description}
              date={p.data.date}
              tags={p.data.tags}
              slug={p.id}
            />
          ))}
        </div>
      </section>
    )}

    <!-- Projects -->
    {allProjects.length > 0 && (
      <section class="section">
        <div class="section-header">
          <span class="section-label">Projects</span>
          <a href="/projects">All →</a>
        </div>
        <div class="projects-grid">
          {allProjects.map(p => (
            <ProjectCard
              title={p.data.title}
              description={p.data.description}
              tags={p.data.tags}
              status={p.data.status}
              url={p.data.url}
              github={p.data.github}
              image={p.data.image}
              slug={p.id}
            />
          ))}
        </div>
      </section>
    )}

  </div>

</Base>

<style>
  .page { padding-bottom: 5rem; }

  /* Hero */
  .hero { padding: 4rem 0 3rem; }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-bottom: 1rem;
    letter-spacing: 0.02em;
  }

  .dot {
    width: 6px; height: 6px;
    background: #2d9e6b;
    border-radius: 50%;
    animation: pulse 2.5s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.2; }
  }

  h1 {
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    margin-bottom: 0.75rem;
    line-height: 1.25;
  }

  h1 em { color: var(--text-muted); font-style: italic; }

  .sub {
    font-size: 0.95rem;
    color: var(--text-muted);
    max-width: 460px;
    margin-bottom: 1.75rem;
    line-height: 1.7;
  }

  .cta { display: flex; gap: 0.6rem; flex-wrap: wrap; }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 1.1rem;
    background: var(--text);
    color: #fff;
    border-radius: 5px;
    font-size: 0.85rem;
    font-weight: 500;
    transition: opacity 0.15s;
  }
  .btn-primary:hover { opacity: 0.75; color: #fff; }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 1.1rem;
    border: 1px solid var(--border-strong);
    border-radius: 5px;
    font-size: 0.85rem;
    color: var(--text-muted);
    transition: all 0.15s;
  }
  .btn-ghost:hover { color: var(--text); border-color: var(--text); }

  .socials {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 1.25rem;
  }

  .socials a {
    color: var(--text-faint);
    display: flex;
    align-items: center;
    transition: color 0.15s;
  }
  .socials a:hover { color: var(--text-muted); }

  /* Sections */
  .section { padding: 2.5rem 0 0; }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }

  .section-label {
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-faint);
  }

  .section-header a {
    font-size: 0.78rem;
    color: var(--text-faint);
  }
  .section-header a:hover { color: var(--text-muted); }

  /* Posts */
  .posts-list { display: flex; flex-direction: column; }

  /* Projects */
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
  }

  @media (max-width: 640px) {
    .projects-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 400px) {
    .projects-grid { grid-template-columns: 1fr; }
  }
</style>

---
import Base from '../layouts/Base.astro';
import PostCard from '../components/PostCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);

const allProjects = (await getCollection('projects'))
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 6);
---

<Base title="Saran — Builder & Founder" description="I build things at the intersection of product, AI, and design.">

  <div class="container page">

    <!-- Hero -->
    <section class="hero">
      <div class="eyebrow"><span class="dot"></span>Available for new projects</div>
      <h1>Engineer. Builder. <em>Occasional writer.</em></h1>
      <p class="sub">Working at the intersection of AI, product, and software. Currently building at Tekvo and Milao.</p>
      <div class="cta">
        <a href="/blog" class="btn-primary">Read the blog</a>
        <a href="/projects" class="btn-ghost">See my work</a>
      </div>
    </section>

    <!-- Writing -->
    {allPosts.length > 0 && (
      <section class="section">
        <div class="section-header">
          <span class="section-label">Writing</span>
          <a href="/blog">All posts →</a>
        </div>
        <div class="posts-list">
          {allPosts.map(p => (
            <PostCard
              title={p.data.title}
              description={p.data.description}
              date={p.data.date}
              tags={p.data.tags}
              slug={p.id}
            />
          ))}
        </div>
      </section>
    )}

    <!-- Projects -->
    {allProjects.length > 0 && (
      <section class="section">
        <div class="section-header">
          <span class="section-label">Projects</span>
          <a href="/projects">All →</a>
        </div>
        <div class="projects-grid">
          {allProjects.map(p => (
            <ProjectCard
              title={p.data.title}
              description={p.data.description}
              tags={p.data.tags}
              status={p.data.status}
              url={p.data.url}
              github={p.data.github}
              image={p.data.image}
              slug={p.id}
            />
          ))}
        </div>
      </section>
    )}

  </div>

</Base>

<style>
  .page { padding-bottom: 4rem; }

  /* Hero */
  .hero { padding: 2.5rem 0 2rem; }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.72rem;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
    letter-spacing: 0.02em;
  }

  .dot {
    width: 6px; height: 6px;
    background: #2d9e6b;
    border-radius: 50%;
    animation: pulse 2.5s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.2; }
  }

  h1 {
    font-size: clamp(1.45rem, 3vw, 2rem);
    margin-bottom: 0.5rem;
    line-height: 1.3;
  }

  h1 em { color: var(--text-muted); font-style: italic; }

  .sub {
    font-size: 0.85rem;
    color: var(--text-muted);
    max-width: 420px;
    margin-bottom: 1.1rem;
    line-height: 1.65;
  }

  .cta { display: flex; gap: 0.5rem; flex-wrap: wrap; }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    padding: 0.38rem 0.9rem;
    background: var(--text);
    color: #fff;
    border-radius: 5px;
    font-size: 0.78rem;
    font-weight: 500;
    transition: opacity 0.15s;
  }
  .btn-primary:hover { opacity: 0.75; color: #fff; }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    padding: 0.38rem 0.9rem;
    border: 1px solid var(--border-strong);
    border-radius: 5px;
    font-size: 0.78rem;
    color: var(--text-muted);
    transition: all 0.15s;
  }
  .btn-ghost:hover { color: var(--text); border-color: var(--text); }

  /* Sections */
  .section { padding: 1.75rem 0 0; }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }

  .section-label {
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-faint);
  }

  .section-header a {
    font-size: 0.78rem;
    color: var(--text-faint);
  }
  .section-header a:hover { color: var(--text-muted); }

  /* Posts */
  .posts-list { display: flex; flex-direction: column; }

  /* Projects */
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
  }

  @media (max-width: 640px) {
    .projects-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 400px) {
    .projects-grid { grid-template-columns: 1fr; }
  }
</style>
